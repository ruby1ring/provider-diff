{
  "name": "provider-diff",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "rebuild:docs": "node scripts/rebuild-docs.mjs --force",
    "build:protocol-matrix": "node scripts/inject-protocol-frontmatter.mjs && node scripts/build-protocol-matrix.mjs && node scripts/audit-protocol-types.mjs",
    "build:error-code-catalog": "node scripts/build-error-code-catalog.mjs",
    "desktop:dev": "node scripts/build-dmg.js --skip-package && electron .",
    "build:evalscope-service": "node scripts/build-evalscope-service.js",
    "dist:dmg": "node scripts/build-dmg.js"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "cn.siliconflow.noctua",
    "productName": "Noctua",
    "asar": false,
    "files": [
      "web/index.html",
      "web/main.js",
      "web/lib/**",
      "web/data/**",
      "package.json",
      "assets/**",
      "design-system/**",
      "docs/**",
      "outputs/**",
      "payloads/**",
      "desktop/main.js"
    ],
    "extraResources": [
      {
        "from": "desktop/bin/provider-diff-backend",
        "to": "backend/provider-diff-backend"
      },
      {
        "from": "desktop/bin/llm-bench",
        "to": "backend/llm-bench"
      },
      {
        "from": "desktop/services",
        "to": "services"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "icon": "build/icon.icns",
      "artifactName": "Noctua-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@larksuite/cli": "^1.0.45"
  }
}
