{
  "case_id": "thinking_object_enabled_budget_tokens",
  "title": "thinking.type=enabled with budget_tokens opens thinking",
  "category": "reasoning",
  "parameters": ["thinking", "thinking.budget_tokens"],
  "requires_model_capability": "thinking",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-5.1",
    "messages": [
      {
        "role": "user",
        "content": "Use concise reasoning to compute 41 + 17, then give the final answer."
      }
    ],
    "thinking": {
      "type": "enabled",
      "budget_tokens": 1024
    },
    "max_completion_tokens": 1400
  },
  "expect": {
    "http_status": 200,
    "thinking_location_probe": true,
    "thinking_evidence_required": true,
    "assistant_content_non_empty": true,
    "provider_extension": true,
    "notes": "Claude-style extended thinking 通常要求 thinking.budget_tokens；DeepSeek-style provider 可能接受或拒绝该额外字段。"
  }
}
