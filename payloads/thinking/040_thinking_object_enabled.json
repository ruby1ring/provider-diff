{
  "case_id": "thinking_object_enabled",
  "title": "thinking.type=enabled opens thinking",
  "category": "reasoning",
  "parameters": ["thinking"],
  "requires_model_capability": "thinking",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-5.1",
    "messages": [
      {
        "role": "user",
        "content": "Use brief reasoning to compute 41 + 17, then give the final answer."
      }
    ],
    "thinking": {
      "type": "enabled"
    },
    "max_completion_tokens": 512
  },
  "expect": {
    "http_status": 200,
    "thinking_location_probe": true,
    "thinking_evidence_required": true,
    "assistant_content_non_empty": true,
    "provider_extension": true,
    "notes": "DeepSeek/Claude-style object 开启形态；部分渠道可能还需要 budget_tokens。"
  }
}
