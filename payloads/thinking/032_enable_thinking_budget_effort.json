{
  "case_id": "thinking_enable_thinking_budget_effort",
  "title": "enable_thinking + thinking_budget + reasoning_effort",
  "category": "reasoning",
  "parameters": ["enable_thinking", "thinking_budget", "reasoning_effort"],
  "requires_model_capability": "reasoning",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-5.1",
    "messages": [
      {
        "role": "user",
        "content": "Use concise reasoning to compute 34 + 58, then give the final answer."
      }
    ],
    "enable_thinking": true,
    "thinking_budget": 768,
    "reasoning_effort": "medium",
    "max_completion_tokens": 1200
  },
  "expect": {
    "http_status": 200,
    "thinking_location_probe": true,
    "thinking_evidence_required": true,
    "assistant_content_non_empty": true,
    "provider_extension": true,
    "notes": "硅基流动等 Qwen 方言常见三参数组合：enable_thinking + thinking_budget + reasoning_effort（后者为部分模型扩展探针）。"
  }
}
