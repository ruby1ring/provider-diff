{
  "case_id": "or_usage_cost_fields",
  "title": "非流式响应应包含 usage token 字段并可返回 OpenRouter cost 字段",
  "category": "observability",
  "parameters": [
    "usage",
    "usage.prompt_tokens",
    "usage.completion_tokens",
    "usage.total_tokens",
    "usage.cost",
    "usage.cost_details",
    "usage.is_byok"
  ],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "openai/gpt-4o-mini",
    "messages": [
      {
        "role": "user",
        "content": "Say ok."
      }
    ],
    "max_completion_tokens": 20
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "system_fingerprint", "usage"],
    "usage_required_fields": ["prompt_tokens", "completion_tokens", "total_tokens"],
    "optional_response_fields": ["usage.cost", "usage.cost_details", "usage.is_byok"],
    "notes": "OpenRouter usage schema includes cost and BYOK fields, but exact presence can depend on response mode/account."
  }
}
