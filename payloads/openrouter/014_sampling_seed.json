{
  "case_id": "or_sampling_seed",
  "title": "seed should be accepted",
  "category": "sampling",
  "parameters": ["seed"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "openai/gpt-4o-mini",
    "messages": [
      {
        "role": "user",
        "content": "Return exactly one color name."
