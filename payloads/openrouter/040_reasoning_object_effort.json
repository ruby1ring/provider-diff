{
  "case_id": "or_reasoning_object_effort",
  "title": "reasoning object should be accepted on reasoning-capable models",
  "category": "reasoning",
  "parameters": ["reasoning", "reasoning.effort", "reasoning.summary"],
  "requires_model_capability": "reasoning",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "openai/gpt-5.2",
    "messages": [
      {
        "role": "user",
        "content": "Solve briefly: if 3 providers each have 4 tests, how many tests?"
      }
    ],
    "reasoning": {
      "effort": "low",
      "summary": "concise"
    },
    "max_completion_tokens": 120
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "system_fingerprint"],
    "optional_response_fields": ["choices[].message.reasoning", "choices[].message.reasoning_details", "usage.completion_tokens_details.reasoning_tokens"],
    "thinking_location_probe": true,
    "thinking_evidence_required": true,
    "notes": "Capability-gated. Runner may override model; use a reasoning-capable model. 开启判定要求出现 reasoning/reasoning_details 或 reasoning_tokens/thinking_tokens 证据。"
  }
}
