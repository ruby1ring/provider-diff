{
  "provider": "openrouter",
  "base_url": "https://openrouter.ai/api/v1",
  "endpoint": "/chat/completions",
  "method": "POST",
  "source": "../../docs/openrouter.md",
  "default_model": "openai/gpt-4o-mini",
  "reasoning_model": "openai/gpt-5.2",
  "vision_model": "openai/gpt-4o-mini",
  "notes": [
    "All cases validate OpenRouter request acceptance and normalized response shape, not exact generated text.",
    "OpenRouter support can depend on the selected upstream model/provider.",
    "Set provider.require_parameters=true in targeted cases when the test must prove the upstream supports every supplied parameter.",
    "Optional cases may require specific model, provider, plugin, or account capability.",
    "The current runner cannot attach OpenRouter attribution or experimental metadata headers per case."
  ],
  "common_expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "system_fingerprint"],
    "choice_required_fields": ["index", "message", "finish_reason"],
    "usage_required_fields": ["prompt_tokens", "completion_tokens", "total_tokens"]
  },
