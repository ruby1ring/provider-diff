{
  "case_id": "or_multimodal_image_url_optional",
  "title": "image_url content part should be accepted on vision-capable models",
  "category": "multimodal",
  "parameters": ["messages[].content[].image_url"],
  "requires_model_capability": "vision",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "openai/gpt-4o-mini",
    "messages": [
      {
        "role": "user",
        "content": [
          {
            "type": "text",
            "text": "Describe this image in one short phrase."
          },
          {
            "type": "image_url",
            "image_url": {
              "url": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAACAAAAAgCAYAAABzenr0AAAAMElEQVR4nO3OIQEAAAgDMJIQgv5R6AIxbibmV9tzSSUgICAgICAgICAgICAgIJAOPO8DrHnALMiOAAAAAElFTkSuQmCC",
              "detail": "low"
            }
          }
        ]
      }
    ],
    "max_completion_tokens": 80
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "system_fingerprint"],
    "notes": "Capability-gated vision test. Uses a small data URL instead of a remote URL so upstream image fetching does not affect protocol validation."
  }
}
