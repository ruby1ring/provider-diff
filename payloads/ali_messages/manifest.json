{
  "provider": "ali_messages",
  "base_url": "https://dashscope.aliyuncs.com/apps/anthropic/v1",
  "endpoint": "/messages",
  "method": "POST",
  "source": "../../docs/api/ali-message.md",
  "default_model": "deepseek-v4-pro",
  "reasoning_model": "deepseek-v4-pro",
  "vision_model": "qwen-vl-plus",
  "notes": [
    "Anthropic Messages compatibility tests use /v1/messages-style request bodies.",
    "OpenAI Official intentionally has no corresponding Messages endpoint in this UI.",
    "Validate parameter acceptance and broad response shape, not exact generated text."
  ],
  "common_expect": {
    "http_status": 200,
    "required_response_fields": [
      "id",
      "type",
      "role",
      "content",
      "model"
    ],
    "content_required_fields": [
      "type"
    ]
  },
  "cases": [
    "001_messages_minimal.json",
    "002_messages_system.json",
    "010_sampling_temperature.json",
    "011_sampling_top_p.json",
    "012_sampling_top_k.json",
    "020_length_max_tokens.json",
    "030_stop_sequences.json",
    "040_tools_auto.json",
    "050_stream_basic.json",
    "051_stream_false.json",
    "052_protocol_sampling_temperature_1.json",
    "053_protocol_sampling_temperature_2.json",
    "054_protocol_sampling_temperature_1_0.json",
    "055_protocol_sampling_temperature_2_0.json",
    "060_thinking_budget.json"
  ]
}
