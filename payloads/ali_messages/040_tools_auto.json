{
  "case_id": "am_tools_auto",
  "title": "tools should be accepted on Messages endpoint",
  "category": "tools",
  "parameters": [
    "tools",
    "tool_choice"
  ],
  "optional": true,
  "method": "POST",
  "path": "/v1/messages",
  "payload": {
    "model": "deepseek-v4-pro",
    "max_tokens": 128,
    "tool_choice": {
      "type": "auto"
    },
    "tools": [
      {
        "name": "get_weather",
        "description": "Get weather for a city.",
        "input_schema": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string"
            }
          },
          "required": [
            "location"
          ]
        }
      }
    ],
    "messages": [
      {
        "role": "user",
        "content": "What is the weather in Shanghai? Use the tool if needed."
      }
    ],
    "thinking": {
      "type": "disabled"
    }
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": [
      "id",
      "type",
      "role",
      "content",
      "model"
    ],
    "notes": "Current test config has DashScope Messages access to deepseek-v4-pro, so this case uses it for API-level compatibility validation. 关闭 thinking 后验证该参数，避免 DashScope Messages 将 reasoning token 计入 usage.output_tokens。"
  }
}
