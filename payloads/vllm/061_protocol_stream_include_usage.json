{
  "case_id": "vllm_protocol_stream_include_usage",
  "title": "Streaming response with usage chunk",
  "category": "protocol",
  "parameters": ["stream", "stream_options.include_usage"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "NousResearch/Meta-Llama-3-8B-Instruct",
    "messages": [{"role": "user", "content": "Stream a short sentence about usage."}],
    "stream": true,
    "stream_options": {
      "include_usage": true
    },
    "max_tokens": 48
  },
  "expect": {
    "response_mode": "sse",
    "required_chunk_fields": ["id", "object", "created", "model", "choices"],
    "usage_required_fields": ["prompt_tokens", "completion_tokens", "total_tokens"],
    "optional_capability_mismatch": true,
    "notes": "Some vLLM versions or interrupted streams may omit the final usage chunk."
  }
}
