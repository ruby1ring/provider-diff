{
  "case_id": "vllm_reasoning_effort_high_enable_false_override",
  "title": "explicit enable_thinking=false overrides reasoning_effort=high",
  "category": "reasoning",
  "parameters": ["reasoning_effort", "chat_template_kwargs.enable_thinking"],
  "requires_model_capability": "reasoning",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "Qwen/Qwen3-8B",
    "messages": [
      {
        "role": "user",
        "content": "Compute 89 + 34. Reply with one short sentence."
      }
    ],
    "reasoning_effort": "high",
    "chat_template_kwargs": {
      "enable_thinking": false
    },
    "max_tokens": 160
  },
  "expect": {
    "thinking_location_probe": true,
    "thinking_absent": true,
    "assistant_content_non_empty": true,
    "provider_extension": true,
    "notes": "vLLM docs say explicitly supplied chat_template_kwargs.enable_thinking takes priority over reasoning_effort automatic injection."
  }
}
