{
  "case_id": "vllm_reasoning_chat_template_enable_false",
  "title": "chat_template_kwargs.enable_thinking=false should disable thinking",
  "category": "reasoning",
  "parameters": ["chat_template_kwargs.enable_thinking"],
  "requires_model_capability": "reasoning",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "Qwen/Qwen3-8B",
    "messages": [
      {
        "role": "user",
        "content": "Compute 52 + 16. Reply with one short sentence."
      }
    ],
    "chat_template_kwargs": {
      "enable_thinking": false
    },
    "max_tokens": 128
  },
  "expect": {
    "thinking_location_probe": true,
    "thinking_absent": true,
    "assistant_content_non_empty": true,
    "provider_extension": true,
    "notes": "For Qwen3, vLLM docs describe enable_thinking=false as a strict switch to disable reasoning output."
  }
}
