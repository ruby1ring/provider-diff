{
  "case_id": "am_tools_auto",
  "title": "tools should be accepted on Messages endpoint",
  "category": "tools",
  "parameters": [
    "tools",
    "tool_choice"
  ],
  "optional": true,
  "method": "POST",
  "path": "/v1/messages",
  "payload": {
    "model": "Pro/zai-org/GLM-4.7",
    "max_tokens": 128,
    "thinking": {
      "type": "disabled"
    },
    "tool_choice": {
      "type": "auto"
    },
    "tools": [
      {
        "name": "get_weather",
        "description": "Get weather for a city.",
        "input_schema": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string"
            }
          },
          "required": [
            "location"
          ]
        }
      }
    ],
    "messages": [
      {
        "role": "user",
        "content": "What is the weather in Shanghai? Use the tool if needed."
      }
    ]
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": [
      "id",
      "type",
      "role",
      "content",
      "model"
    ]
  }
}
