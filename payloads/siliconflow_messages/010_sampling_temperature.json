{
  "case_id": "am_sampling_temperature",
  "title": "Messages 接口接受 temperature",
  "category": "sampling",
  "parameters": [
    "temperature"
  ],
  "method": "POST",
  "path": "/v1/messages",
  "payload": {
    "model": "Pro/zai-org/GLM-4.7",
    "max_tokens": 64,
    "thinking": {
      "type": "disabled"
    },
    "temperature": 0.2,
    "messages": [
      {
        "role": "user",
        "content": "Write one short sentence about routing."
      }
    ]
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": [
      "id",
      "type",
      "role",
      "content",
      "model"
    ]
  }
}
