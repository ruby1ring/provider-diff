{
  "case_id": "ali_search_enable_search",
  "title": "enable_search 联网搜索",
  "category": "search",
  "parameters": [
    "enable_search"
  ],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-v4-pro",
    "messages": [
      {
        "role": "user",
        "content": "今天日期相关问题如果需要可联网搜索：请回答当前年份。"
      }
    ],
    "enable_search": true
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": [
      "id",
      "object",
      "created",
      "model",
      "choices",
      "usage"
    ],
    "provider_extension": true,
    "notes": "enable_search 是非 OpenAI 标准参数；开启可能增加 token 消耗。 Current test config has DashScope access to deepseek-v4-pro, so this case uses it for API-level compatibility validation."
  }
}
