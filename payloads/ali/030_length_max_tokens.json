{
  "case_id": "ali_length_max_tokens",
  "title": "max_tokens 限制输出长度",
  "category": "length",
  "parameters": [
    "max_tokens"
  ],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-v4-pro",
    "messages": [
      {
        "role": "user",
        "content": "用不超过二十个字解释单元测试。"
      }
    ],
    "max_tokens": 32,
    "enable_thinking": false
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": [
      "id",
      "object",
      "created",
      "model",
      "choices",
      "usage"
    ],
    "notes": "deepseek-v4-pro 默认 reasoning token 会计入 completion_tokens；关闭 enable_thinking 后验证 max_tokens 限制。"
  }
}
