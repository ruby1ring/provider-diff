{
  "case_id": "ali_tools_auto",
  "title": "tools 与 tool_choice=auto",
  "category": "tools",
  "parameters": [
    "tools",
    "tool_choice"
  ],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-v4-pro",
    "messages": [
      {
        "role": "user",
        "content": "上海现在天气如何？需要时调用工具。"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get_current_weather",
          "description": "查询城市当前天气。",
          "parameters": {
            "type": "object",
            "properties": {
              "location": {
                "type": "string",
                "description": "城市名称"
              },
              "unit": {
                "type": "string",
                "enum": [
                  "celsius",
                  "fahrenheit"
                ]
              }
            },
            "required": [
              "location"
            ]
          }
        }
      }
    ],
    "tool_choice": "auto"
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": [
      "id",
      "object",
      "created",
      "model",
      "choices",
      "usage"
    ],
    "optional_response_fields": [
      "choices[].message.tool_calls"
    ],
    "notes": "模型可能直接回答，也可能返回 tool_calls；这里只验证请求和结构。 Current test config has DashScope access to deepseek-v4-pro, so this case uses it for API-level compatibility validation."
  }
}
