{
  "case_id": "ali_basic_system_user",
  "title": "system 与 user 消息",
  "category": "basic",
  "parameters": [
    "model",
    "messages"
  ],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-v4-pro",
    "messages": [
      {
        "role": "system",
        "content": "你是一个回答简洁的助手。"
      },
      {
        "role": "user",
        "content": "请用一句话解释什么是 API。"
      }
    ]
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": [
