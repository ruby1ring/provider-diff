  "expect": {
    "http_status": 200,
    "support_conclusion": "ignored",
    "notes": "MiniMax docs say audio input is not currently supported on OpenAI-compatible endpoint. Real test returned HTTP 200; the provider appears to ignore or coerce this field instead of rejecting it."
  }
