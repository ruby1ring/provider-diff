{
  "case_id": "sf_response_format_json_schema",
  "title": "response_format json_schema should be accepted",
  "category": "output",
  "parameters": ["response_format"],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "Pro/zai-org/GLM-4.7",
    "messages": [
      {
        "role": "system",
        "content": "Return valid JSON only. No markdown."
      },
      {
        "role": "user",
        "content": "Return a compliance result for parameter temperature with status accepted."
      }
    ],
    "response_format": {
      "type": "json_schema",
      "json_schema": {
        "name": "compatibility_result",
        "schema": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "parameter": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": ["accepted", "rejected", "warning"]
            },
            "notes": {
              "type": "string"
            }
          },
          "required": ["parameter", "status", "notes"]
        }
      }
    }
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "content_should_parse_as_json": true,
    "notes": "JSON schema is preferred where supported. Validate schema-like output if runner supports content assertions."
  }
}
