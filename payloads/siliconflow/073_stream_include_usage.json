{
  "case_id": "sf_stream_include_usage",
  "title": "stream_options.include_usage 应返回 usage chunk",
  "category": "protocol",
  "parameters": ["stream", "stream_options", "stream_options.include_usage"],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "Pro/zai-org/GLM-4.7",
    "messages": [
      {
        "role": "user",
        "content": "Stream one short sentence about usage accounting."
      }
    ],
    "stream": true,
    "enable_thinking": false,
    "max_tokens": 80,
    "stream_options": {
      "include_usage": true
    }
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "response_mode": "sse",
    "required_chunk_fields": ["id", "object", "created", "model", "choices"],
    "usage_required_fields": [
      "prompt_tokens",
      "completion_tokens",
      "total_tokens",
      "completion_tokens_details.reasoning_tokens",
      "prompt_tokens_details.cached_tokens",
      "prompt_cache_hit_tokens",
      "prompt_cache_miss_tokens"
    ],
    "notes": "include_usage=true should produce at least one SSE chunk containing usage."
  }
}
