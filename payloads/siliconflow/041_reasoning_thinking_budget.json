{
  "case_id": "sf_reasoning_thinking_budget",
  "title": "enable_thinking with thinking_budget should be accepted on a reasoning-capable model",
  "category": "reasoning",
  "parameters": ["enable_thinking", "thinking_budget"],
  "requires_model_capability": "reasoning",
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-ai/DeepSeek-R1",
    "messages": [
      {
        "role": "user",
        "content": "Think briefly, then answer only with the number: 17 + 25."
      }
    ],
    "enable_thinking": true,
    "thinking_budget": 512
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "optional_response_fields": ["choices[].message.reasoning_content", "usage.completion_tokens_details.reasoning_tokens"],
    "provider_extension": true,
    "notes": "Tests provider-specific thinking budget control."
  }
}
