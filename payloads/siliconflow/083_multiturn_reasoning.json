{
  "case_id": "sf_multiturn_reasoning",
  "title": "multi-turn reasoning case should not feed prior reasoning_content back",
  "category": "multiturn",
  "parameters": ["messages", "enable_thinking", "thinking_budget"],
  "requires_model_capability": "reasoning",
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-ai/DeepSeek-R1",
    "messages": [
      {
        "role": "system",
        "content": "Give concise final answers."
      },
      {
        "role": "user",
        "content": "If there are 2 providers and each has 3 tests, how many tests?"
      },
      {
        "role": "assistant",
        "content": "There are 6 tests."
      },
      {
        "role": "user",
        "content": "Add one provider with 3 more tests. What is the new total?"
      }
    ],
    "enable_thinking": true,
    "thinking_budget": 512
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "optional_response_fields": ["choices[].message.reasoning_content"],
    "notes": "Do not include any previous reasoning_content in messages; docs say reasoning content is not appended to next-round context."
  }
}
