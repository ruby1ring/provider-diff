{
  "case_id": "sf_reasoning_enable_thinking",
  "title": "enable_thinking should be accepted on a reasoning-capable model",
  "category": "reasoning",
  "parameters": ["enable_thinking"],
  "requires_model_capability": "reasoning",
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "deepseek-ai/DeepSeek-R1",
    "messages": [
      {
        "role": "user",
        "content": "Solve briefly: if a test suite has 4 groups and 3 cases per group, how many cases are there?"
      }
    ],
    "enable_thinking": true
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "optional_response_fields": ["choices[].message.reasoning_content", "usage.completion_tokens_details.reasoning_tokens"],
    "provider_extension": true,
    "notes": "Capability-gated. If model is unavailable, skip rather than mark incompatible."
  }
}
