{
  "provider": "siliconflow",
  "base_url": "https://api.siliconflow.cn/v1",
  "endpoint": "/chat/completions",
  "method": "POST",
  "source": "../../docs/siliconflow.md",
  "default_model": "Pro/zai-org/GLM-4.7",
  "reasoning_model": "deepseek-ai/DeepSeek-R1",
  "vision_model": "zai-org/GLM-4.6V",
  "notes": [
    "All cases are intended as normal/accepted-path tests unless optional or capability-gated.",
    "Validate response structure and parameter acceptance, not exact generated text.",
    "For reasoning cases, use a model that supports reasoning fields.",
    "For stream cases, validate SSE/chunk framing instead of a normal JSON response body."
  ],
  "common_expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "choice_required_fields": ["index", "message", "finish_reason"],
    "usage_required_fields": ["prompt_tokens", "completion_tokens", "total_tokens"]
  },
  "cases": [
    "001_basic_minimal.json",
    "002_basic_system_user.json",
    "003_basic_multimessage_context.json",
    "010_sampling_temperature_low.json",
    "011_sampling_top_p.json",
    "012_sampling_top_k.json",
    "013_sampling_min_p.json",
    "014_sampling_frequency_penalty.json",
    "015_sampling_n_one.json",
    "016_sampling_stop_string.json",
    "017_sampling_stop_array.json",
    "018_sampling_stop_null.json",
    "020_sampling_combo_temperature_top_p.json",
    "021_sampling_combo_top_p_top_k_min_p.json",
    "022_sampling_combo_penalty_stop.json",
    "030_length_max_tokens.json",
    "031_length_max_tokens_stop.json",
    "040_reasoning_enable_thinking.json",
    "041_reasoning_thinking_budget.json",
    "042_reasoning_effort_medium.json",
    "043_reasoning_combo_budget_effort.json",
    "044_reasoning_disable_thinking_no_output.json",
    "050_response_format_text.json",
    "051_response_format_json_object.json",
    "052_response_format_json_schema.json",
    "060_tools_auto.json",
    "061_tools_named_function_hint.json",
    "062_tools_multiturn_tool_result.json",
    "070_stream_basic.json",
    "071_stream_with_max_tokens.json",
    "072_stream_with_tools_auto.json",
    "073_stream_include_usage.json",
    "080_multiturn_basic.json",
    "081_multiturn_with_system_policy.json",
    "082_multiturn_json_object.json",
    "083_multiturn_reasoning.json",
    "084_multiturn_tools.json",
    "090_observability_trace_header.json",
    "091_multimodal_image_url.json",
    "092_multimodal_multi_image_compare.json",
    "093_observability_usage_fields.json"
  ]
}
