{
  "case_id": "sf_response_format_json_object",
  "title": "response_format json_object should be accepted",
  "category": "output",
  "parameters": ["response_format"],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "Pro/zai-org/GLM-4.7",
    "messages": [
      {
        "role": "system",
        "content": "You must return valid JSON only. No markdown."
      },
      {
        "role": "user",
        "content": "Return {\"status\":\"ok\",\"provider\":\"siliconflow\"} with no extra fields."
      }
    ],
    "response_format": {
      "type": "json_object"
    }
  },
  "expect": {
    "http_status": 200,
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "content_should_parse_as_json": true,
    "notes": "Prompt explicitly instructs JSON because docs warn JSON mode still needs a JSON instruction."
  }
}
