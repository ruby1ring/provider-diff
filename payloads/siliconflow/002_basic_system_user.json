{
  "case_id": "sf_basic_system_user",
  "title": "System and user messages should be accepted",
  "category": "basic",
  "parameters": ["model", "messages"],
  "method": "POST",
  "path": "/v1/chat/completions",
  "payload": {
    "model": "Pro/zai-org/GLM-4.7",
