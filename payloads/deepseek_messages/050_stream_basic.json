{
  "case_id": "am_protocol_stream",
  "title": "stream true should return SSE on Messages endpoint",
  "category": "protocol",
  "parameters": ["stream"],
  "method": "POST",
  "path": "/v1/messages",
  "payload": {
    "model": "deepseek-v4-flash",
    "max_tokens": 64,
    "stream": true,
    "messages": [
      { "role": "user", "content": "Say hi in one sentence." }
    ]
  },
  "expect": {
    "http_status": 200,
    "response_mode": "sse"
  }
