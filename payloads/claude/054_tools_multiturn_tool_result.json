{
  "case_id": "claude_tools_multiturn_tool_result",
  "title": "tool result 多轮续写",
  "category": "tools",
  "parameters": ["messages[].role=tool", "messages[].tool_call_id"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "claude-sonnet-4-6",
    "messages": [
      {"role": "user", "content": "上海天气如何？"},
      {
        "role": "assistant",
        "content": null,
        "tool_calls": [
          {
            "id": "call_weather_1",
            "type": "function",
            "function": {
              "name": "get_current_weather",
              "arguments": "{\"location\":\"Shanghai\",\"unit\":\"celsius\"}"
            }
          }
        ]
      },
      {
        "role": "tool",
        "tool_call_id": "call_weather_1",
        "content": "{\"temperature\":22,\"unit\":\"celsius\",\"condition\":\"clear\"}"
      },
      {"role": "user", "content": "用一句话总结工具结果。"}
    ],
    "max_completion_tokens": 80
  },
  "expect": {
    "assistant_content_non_empty": true
  }
}
