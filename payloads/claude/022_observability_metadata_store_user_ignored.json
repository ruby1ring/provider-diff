{
  "case_id": "claude_observability_metadata_store_user_ignored",
  "title": "metadata、store 和 user 被忽略",
  "category": "observability",
  "parameters": ["metadata", "store", "user"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "claude-sonnet-4-6",
