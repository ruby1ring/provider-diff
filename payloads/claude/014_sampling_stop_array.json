{
  "case_id": "claude_sampling_stop_array",
  "title": "stop 数组",
  "category": "sampling",
  "parameters": ["stop"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "claude-sonnet-4-6",
    "messages": [
      {"role": "user", "content": "请严格写出：alpha END beta"}
    ],
    "stop": ["END"],
    "max_completion_tokens": 60
  },
  "expect": {
    "allowed_finish_reasons": ["stop", "length"],
    "notes": "文档说明所有非空白 stop sequences 都可生效。"
  }
}
