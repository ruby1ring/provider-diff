{
  "case_id": "claude_multimodal_image_url",
  "title": "image_url 内容块",
  "category": "multimodal",
  "parameters": ["messages[].content[].image_url"],
  "requires_model_capability": "vision",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "claude-sonnet-4-6",
    "messages": [
      {
        "role": "user",
        "content": [
          {"type": "text", "text": "用一个简短短语描述这张图片。"},
          {
            "type": "image_url",
            "image_url": {
              "url": "https://upload.wikimedia.org/wikipedia/commons/thumb/3/3f/Fronalpstock_big.jpg/320px-Fronalpstock_big.jpg"
            }
          }
        ]
      }
    ],
    "max_completion_tokens": 80
  },
  "expect": {
    "assistant_content_non_empty": true,
    "notes": "官方文档说明 image_url.url 被完整支持。"
  }
}
