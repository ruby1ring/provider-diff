{
  "case_id": "oa_multimodal_audio_input",
  "title": "input_audio content part",
  "category": "multimodal",
  "parameters": ["messages[].content[].input_audio"],
  "requires_model_capability": "audio_input",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini-audio-preview",
    "messages": [
      {
        "role": "user",
        "content": [
          {"type": "text", "text": "This is a short silent WAV. Reply with one short phrase."},
          {
            "type": "input_audio",
            "input_audio": {
              "format": "wav",
              "data": ""
            }
          }
        ]
      }
    ],
    "max_completion_tokens": 80
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "notes": "Capability-gated audio input case."
  }
}
