{
  "case_id": "oa_observability_usage_fields",
  "title": "非流式响应应包含详细 usage 字段",
  "category": "observability",
  "parameters": [
    "usage",
    "usage.prompt_tokens",
    "usage.completion_tokens",
    "usage.total_tokens",
    "usage.prompt_tokens_details.cached_tokens",
    "usage.completion_tokens_details.reasoning_tokens"
  ],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini",
    "messages": [
      {
        "role": "user",
        "content": "Reply with one short sentence about usage accounting."
      }
    ],
    "max_completion_tokens": 80
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "usage_required_fields": [
      "prompt_tokens",
      "completion_tokens",
      "total_tokens",
      "prompt_tokens_details.cached_tokens",
      "completion_tokens_details.reasoning_tokens"
    ],
    "notes": "Diagnoses whether non-stream JSON responses expose OpenAI usage detail fields documented for Chat Completions."
  }
}
