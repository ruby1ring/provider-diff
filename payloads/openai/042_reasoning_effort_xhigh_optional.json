{
  "case_id": "oa_reasoning_effort_xhigh",
  "title": "reasoning_effort xhigh on newer reasoning models",
  "category": "reasoning",
  "parameters": ["reasoning_effort"],
  "requires_model_capability": "reasoning_xhigh",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-5.4-mini",
    "messages": [{"role": "user", "content": "Check whether 23 is prime and answer yes or no."}],
    "reasoning_effort": "xhigh",
    "max_completion_tokens": 120
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "thinking_location_probe": true,
    "thinking_evidence_required": true,
    "notes": "Optional because xhigh support is model-version dependent. 开启判定要求出现 reasoning_tokens/thinking_tokens 或可见 reasoning 内容证据。"
  }
}
