{
  "case_id": "oa_sampling_combo_core",
  "title": "Core sampling parameters together",
  "category": "sampling",
  "parameters": ["temperature", "top_p", "frequency_penalty", "presence_penalty", "seed"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini",
    "messages": [{"role": "user", "content": "Return one compact sentence about combined sampling controls."}],
    "temperature": 0.3,
    "top_p": 0.9,
    "frequency_penalty": 0.1,
    "presence_penalty": 0.1,
    "seed": 4242,
    "max_completion_tokens": 70
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "notes": "Docs recommend changing temperature or top_p, not both; this case validates parser acceptance for combined fields."
  }
}
