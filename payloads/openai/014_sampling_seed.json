{
  "case_id": "oa_sampling_seed",
  "title": "seed best-effort determinism",
  "category": "sampling",
  "parameters": ["seed"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini",
    "messages": [{"role": "user", "content": "Return one short sentence about seeds."}],
    "seed": 12345,
    "temperature": 0.2,
    "max_completion_tokens": 60
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "notes": "Determinism is best effort; do not assert exact content."
  }
}
