{
  "case_id": "oa_tools_custom_grammar",
  "title": "Custom tool with regex grammar format",
  "category": "tools",
  "parameters": ["tools[].custom.format.type=grammar"],
  "requires_model_capability": "custom_tools",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-5.4-mini",
    "messages": [{"role": "user", "content": "Call emit_status with input OK."}],
    "tools": [
      {
        "type": "custom",
        "custom": {
          "name": "emit_status",
          "description": "Emit a grammar-constrained status.",
          "format": {
            "type": "grammar",
            "grammar": {
              "syntax": "regex",
              "definition": "^OK$"
            }
          }
        }
      }
    ],
    "tool_choice": {
      "type": "custom",
      "custom": {"name": "emit_status"}
    },
    "max_completion_tokens": 120
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "notes": "Optional because custom grammar tools are model-dependent."
  }
}
