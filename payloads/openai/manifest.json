{
  "provider": "openai",
  "base_url": "https://api.openai.com/v1",
  "endpoint": "/chat/completions",
  "method": "POST",
  "source": "../../docs/openai.md",
  "default_model": "gpt-4o-mini",
  "reasoning_model": "gpt-5.1",
  "vision_model": "gpt-4o-mini",
  "notes": [
    "All cases target OpenAI Chat Completions, not the Responses API.",
    "Validate parameter acceptance and normalized response shape, not exact generated text.",
    "Optional cases may require a model with reasoning, vision, audio, web search, or custom tool support.",
    "Use max_completion_tokens for new tests; max_tokens is kept only as a deprecated compatibility probe.",
    "The current runner can override model globally, which can affect model-specific optional cases."
  ],
  "common_expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "choice_required_fields": ["index", "message", "finish_reason"],
    "usage_required_fields": ["prompt_tokens", "completion_tokens", "total_tokens"]
  },
  "cases": [
    "001_basic_minimal.json",
    "002_basic_system_developer_user.json",
    "003_basic_multimessage_context.json",
    "004_basic_content_array_text.json",
    "005_basic_assistant_partial.json",
    "010_sampling_temperature_low.json",
    "011_sampling_top_p.json",
    "012_sampling_frequency_penalty.json",
    "013_sampling_presence_penalty.json",
    "014_sampling_seed.json",
    "015_sampling_logit_bias.json",
    "016_sampling_stop_string.json",
    "017_sampling_stop_array.json",
    "018_sampling_n_two_optional.json",
    "019_sampling_verbosity_optional.json",
    "020_sampling_combo_core.json",
    "030_length_max_completion_tokens.json",
    "031_length_deprecated_max_tokens.json",
    "040_reasoning_effort_low_optional.json",
    "041_reasoning_effort_none_optional.json",
    "042_reasoning_effort_xhigh_optional.json",
    "050_response_format_text.json",
    "051_response_format_json_object.json",
    "052_response_format_json_schema.json",
    "053_prediction_content.json",
    "060_tools_auto.json",
    "061_tools_required.json",
    "062_tools_named_function.json",
    "063_tools_parallel_false.json",
    "064_tools_strict_schema.json",
