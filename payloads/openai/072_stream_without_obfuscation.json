{
  "case_id": "oa_stream_without_obfuscation",
  "title": "Streaming with include_obfuscation false",
  "category": "protocol",
  "parameters": ["stream", "stream_options.include_obfuscation"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini",
    "messages": [{"role": "user", "content": "Stream a compact response."}],
    "stream": true,
    "stream_options": {
      "include_obfuscation": false
    },
    "max_completion_tokens": 60
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "response_mode": "sse",
    "required_chunk_fields": ["id", "object", "created", "model", "choices"],
    "notes": "Validates stream_options.include_obfuscation request shape."
  }
}
