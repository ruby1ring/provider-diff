{
  "case_id": "oa_response_format_json_object",
  "title": "response_format json_object",
  "category": "output",
  "parameters": ["response_format"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini",
    "messages": [
      {"role": "developer", "content": "Return valid JSON only. No markdown."},
      {"role": "user", "content": "Return {\"provider\":\"openai\",\"status\":\"ok\"}."}
    ],
    "response_format": {"type": "json_object"},
    "max_completion_tokens": 80
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "content_should_parse_as_json": true,
    "notes": "JSON mode still needs an instruction to output JSON."
  }
}
