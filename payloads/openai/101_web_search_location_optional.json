{
  "case_id": "oa_web_search_location",
  "title": "web_search_options with approximate user location",
  "category": "web_search",
  "parameters": ["web_search_options.user_location"],
  "requires_model_capability": "web_search",
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini-search-preview",
    "messages": [
      {"role": "user", "content": "Search briefly and mention one local technology headline."}
    ],
    "web_search_options": {
      "search_context_size": "medium",
      "user_location": {
        "type": "approximate",
        "approximate": {
          "city": "San Francisco",
          "region": "California",
          "country": "US",
          "timezone": "America/Los_Angeles"
        }
      }
    },
    "max_completion_tokens": 160
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage"],
    "notes": "Capability-gated web search location case."
  }
}
