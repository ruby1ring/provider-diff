{
  "case_id": "oa_stream_with_usage",
  "title": "流式响应应通过 include_usage 返回 usage",
  "category": "protocol",
  "parameters": ["stream", "stream_options.include_usage"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "gpt-4o-mini",
    "messages": [{"role": "user", "content": "Stream a short sentence about usage chunks."}],
    "stream": true,
    "stream_options": {
      "include_usage": true
    },
    "max_completion_tokens": 60
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "response_mode": "sse",
    "required_chunk_fields": ["id", "object", "created", "model", "choices"],
    "usage_required_fields": [
      "prompt_tokens",
      "completion_tokens",
      "total_tokens",
      "prompt_tokens_details.cached_tokens",
      "completion_tokens_details.reasoning_tokens"
    ],
    "notes": "Final usage chunk can be missing if stream is interrupted."
  }
}
