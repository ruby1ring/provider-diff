{
  "case_id": "am_reasoning_thinking_disabled",
  "title": "Messages 关闭 thinking",
  "category": "reasoning",
  "parameters": ["thinking"],
  "requires_model_capability": "extended_thinking",
  "method": "POST",
  "path": "/v1/messages",
  "payload": {
    "model": "claude-sonnet-4-6",
    "max_tokens": 120,
    "thinking": {
      "type": "disabled"
    },
    "messages": [
      {"role": "user", "content": "简短回答：7 加 5 等于多少？"}
    ]
  },
  "expect": {
    "thinking_absent": true,
    "usage_required_fields": ["input_tokens", "output_tokens"],
    "allowed_finish_reasons": ["end_turn", "max_tokens", "stop_sequence"],
    "notes": "当 thinking 可以关闭时，响应不应包含非空的 content[] thinking block。"
  }
}
