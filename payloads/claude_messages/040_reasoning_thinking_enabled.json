{
  "case_id": "am_reasoning_thinking_budget",
  "title": "Messages thinking 输出与 usage 明细",
  "category": "reasoning",
  "parameters": ["thinking", "thinking_budget_tokens", "usage.output_tokens_details.thinking_tokens"],
  "requires_model_capability": "extended_thinking",
  "method": "POST",
  "path": "/v1/messages",
  "payload": {
    "model": "claude-sonnet-4-6",
    "max_tokens": 1600,
    "thinking": {
      "type": "enabled",
      "budget_tokens": 1024,
      "display": "summarized"
    },
    "messages": [
      {"role": "user", "content": "简短思考并回答：为什么协议测试需要响应结构断言？"}
    ]
  },
  "expect": {
    "thinking_required": true,
    "thinking_location": "messages.content_block",
    "thinking_must_precede_text": true,
    "thinking_required_fields": ["type", "thinking", "signature"],
    "usage_required_fields": ["input_tokens", "output_tokens", "output_tokens_details.thinking_tokens"],
    "allowed_finish_reasons": ["end_turn", "max_tokens", "stop_sequence", "tool_use", "pause_turn", "refusal"],
    "notes": "Extended thinking 必须以非空 content[] block 出现，type=thinking，并且后面跟随普通 text 内容。"
  }
}
