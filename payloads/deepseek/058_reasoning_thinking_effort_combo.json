{
  "case_id": "deepseek_reasoning_thinking_effort_combo",
  "title": "thinking 与 reasoning_effort 组合",
  "category": "reasoning",
  "parameters": ["thinking", "reasoning_effort"],
  "requires_model_capability": "thinking",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {"role": "user", "content": "用两步说明 15 + 27 的结果。"}
    ],
    "thinking": {"type": "enabled"},
    "reasoning_effort": "max"
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage", "system_fingerprint"],
    "optional_response_fields": ["choices[].message.reasoning_content", "usage.completion_tokens_details.reasoning_tokens"],
    "notes": "同时验证 thinking 开关和 reasoning_effort 强度控制。"
  }
}
