{
  "case_id": "deepseek_protocol_stream_include_usage",
  "title": "stream_options.include_usage",
  "category": "protocol",
  "parameters": ["stream", "stream_options", "stream_options.include_usage"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {"role": "user", "content": "流式输出一句关于 usage 的中文说明。"}
    ],
    "stream": true,
    "stream_options": {
      "include_usage": true
    }
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "response_mode": "sse",
    "required_chunk_fields": ["id", "object", "created", "model", "choices"],
    "notes": "include_usage=true 时文档说明会在 [DONE] 前额外返回一个 choices: [] 且带 usage 的 chunk。"
  }
}
