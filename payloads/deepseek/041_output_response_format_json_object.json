{
  "case_id": "deepseek_output_response_format_json_object",
  "title": "response_format=json_object",
  "category": "output",
  "parameters": ["response_format"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {"role": "system", "content": "你必须只输出合法 JSON，不要输出 Markdown。"},
      {"role": "user", "content": "输出 {\"provider\":\"deepseek\",\"ok\":true}。"}
    ],
    "response_format": {"type": "json_object"}
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage", "system_fingerprint"],
    "content_should_parse_as_json": true,
    "notes": "JSON mode 仍需要 prompt 明确要求输出 JSON。"
  }
}
