{
  "case_id": "deepseek_multiturn_basic",
  "title": "基础多轮对话",
  "category": "multiturn",
  "parameters": ["messages"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {"role": "system", "content": "你只输出中文。"},
      {"role": "user", "content": "记住关键词：provider-diff。"},
      {"role": "assistant", "content": "已记住关键词。"},
      {"role": "user", "content": "刚才的关键词是什么？"}
    ]
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage", "system_fingerprint"],
    "choice_required_fields": ["index", "message", "finish_reason"],
    "usage_required_fields": ["prompt_tokens", "completion_tokens", "total_tokens"],
    "notes": "多轮对话基础场景，不只对应单个参数。"
  }
}
