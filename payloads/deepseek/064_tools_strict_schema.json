{
  "case_id": "deepseek_tools_strict_schema",
  "title": "tools[].function.strict",
  "category": "tools",
  "parameters": [
    "tools",
    "tools[].function.strict",
    "tool_choice"
  ],
  "optional": true,
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {
        "role": "user",
        "content": "调用 compatibility_status，返回 stream 的状态。"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "compatibility_status",
          "description": "返回一个参数的兼容性状态。",
          "strict": true,
          "parameters": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "parameter": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "accepted",
                  "ignored",
                  "rejected"
                ]
              }
            },
            "required": [
              "parameter",
              "status"
            ]
          }
        }
      }
    ],
    "tool_choice": {
      "type": "function",
      "function": {
        "name": "compatibility_status"
      }
    },
    "thinking": {
      "type": "disabled"
    }
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": [
      "id",
      "object",
      "created",
      "model",
      "choices",
      "usage",
      "system_fingerprint"
    ],
    "notes": "文档说明 strict 是 beta strict mode；按文档字段构造，可能需要账号或模型能力。 DeepSeek thinking mode rejects forced tool_choice; this case disables thinking to isolate tool_choice behavior."
  }
}
