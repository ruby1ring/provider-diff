{
  "case_id": "deepseek_tools_reasoning_content_replay",
  "title": "tool 调用后保留 reasoning_content",
  "category": "tools",
  "parameters": ["messages", "reasoning_content", "tools", "tool_choice"],
  "requires_model_capability": "thinking",
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {"role": "user", "content": "查询上海天气并总结。"},
      {
        "role": "assistant",
        "content": null,
        "reasoning_content": "用户需要实时天气，需要调用 get_weather。",
        "tool_calls": [
          {
            "id": "call_weather_002",
            "type": "function",
            "function": {
              "name": "get_weather",
              "arguments": "{\"city\":\"上海\"}"
            }
          }
        ]
      },
      {"role": "tool", "tool_call_id": "call_weather_002", "content": "{\"temperature\":24,\"condition\":\"cloudy\"}"},
      {"role": "user", "content": "请继续给出一句中文总结。"}
    ],
    "thinking": {"type": "enabled"},
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get_weather",
          "description": "查询城市天气。",
          "parameters": {"type": "object", "properties": {"city": {"type": "string"}}, "required": ["city"]}
        }
      }
    ],
    "tool_choice": "auto"
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage", "system_fingerprint"],
    "notes": "文档说明 thinking 模式下如果上一轮 assistant 调用 tools，后续请求必须保留 assistant reasoning_content。"
  }
}
