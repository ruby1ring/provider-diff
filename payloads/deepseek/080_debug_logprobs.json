{
  "case_id": "deepseek_debug_logprobs",
  "title": "logprobs=true",
  "category": "debug",
  "parameters": ["logprobs"],
  "method": "POST",
  "path": "/chat/completions",
  "payload": {
    "model": "deepseek-v4-flash",
    "messages": [
      {"role": "user", "content": "只输出一个中文词：你好。"}
    ],
    "logprobs": true,
    "max_tokens": 20
  },
  "expect": {
    "http_status": 200,
    "support_conclusion": "supported",
    "required_response_fields": ["id", "object", "created", "model", "choices", "usage", "system_fingerprint"],
    "notes": "logprobs=true 时响应 choices[].logprobs 可包含 token log probability 详情。"
  }
}
