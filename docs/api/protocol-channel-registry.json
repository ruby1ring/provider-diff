      "top_p": { "type": "number", "range": { "min": 0, "max": 1, "minInclusive": false, "maxInclusive": true } },
      "stop_sequences": { "type": "array" },
      "stream": { "type": "boolean", "default": false }
    },
    "responses_api": {
      "model": { "type": "string" },
      "input": { "type": "string" },
